# wolfprovider_devid.patch — close the devId gap in wolfProvider
#
# What this patch does:
#   1. Adds int devId to WOLFPROV_CTX (internal.h)
#   2. Exposes "wolfprovider_devid" as a settable OSSL_PARAM (wp_wolfprov.c)
#   3. Routes devId through all key init calls for RSA, ECC, DH (wc_InitRsaKey_ex,
#      wc_ecc_init_ex, wc_InitDhKey_ex) — replacing INVALID_DEVID literals
#   4. Routes devId through the ECX gen-context RNG init (wc_InitRng_ex)
#
# Known gap (wolfP11-8gg): ECX key init function pointers in wp_ecx_kmgmt.c
# use WP_ECX_INIT type (int(*)(void*)), which does not carry devId. The
# following init functions are NOT patched for key init devId routing:
#   - wc_curve25519_init (use wc_curve25519_init_ex to fix — needs table change)
#   - wc_ed25519_init    (use wc_ed25519_init_ex to fix — needs table change)
#   - wc_ed448_init      (use wc_ed448_init_ex to fix — needs table change)
#   - wc_curve448_init   (wc_curve448_init_ex does NOT exist in wolfCrypt as of
#                         wolfSSL 5.x — cannot be fixed without wolfCrypt changes)
#
# Impact of the gap: ECX key operations (X25519, X448, Ed25519, Ed448) will
# not route through the wolfHSM device callback for the KEY operation itself.
# The RNG used during key generation WILL use devId (patched). Applications
# that only use RSA, ECC P-256/P-384, and DH are fully covered.
#
# To fully close the ECX gap: change WP_ECX_INIT to int(*)(void*, void*, int)
# and update all four table entries and the wp_ecx_new() call site. That is
# a larger change than this targeted fix and should be a separate PR.
#
# Apply with: patch -p1 -d ~/wolfProvider < wolfprovider_devid.patch
# Verify dry-run first: patch --dry-run -p1 -d ~/wolfProvider < wolfprovider_devid.patch
--- a/include/wolfprovider/internal.h
+++ b/include/wolfprovider/internal.h
@@ -146,6 +146,7 @@
    wolfSSL_Mutex rng_mutex;
 #endif
    BIO_METHOD *coreBioMethod;
+   int devId;
 } WOLFPROV_CTX;
 
 #if defined(WP_HAVE_SEED_SRC) && defined(WP_HAVE_RANDOM)
--- a/src/wp_wolfprov.c	2026-04-07 15:01:26.697081167 -0700
+++ b/src/wp_wolfprov.c	2026-04-07 15:01:47.822651614 -0700
@@ -49,6 +49,7 @@
     OSSL_PARAM_DEFN(OSSL_PROV_PARAM_VERSION, OSSL_PARAM_UTF8_PTR, NULL, 0),
     OSSL_PARAM_DEFN(OSSL_PROV_PARAM_BUILDINFO, OSSL_PARAM_UTF8_PTR, NULL, 0),
     OSSL_PARAM_DEFN(OSSL_PROV_PARAM_STATUS, OSSL_PARAM_INTEGER, NULL, 0),
+    OSSL_PARAM_int("wolfprovider_devid", NULL),
     OSSL_PARAM_END
 };
 
@@ -218,6 +219,9 @@
     WP_CHECK_FIPS_ALGO_PTR(WP_CAST_ALGO_DRBG);
 
     ctx = (WOLFPROV_CTX*)OPENSSL_zalloc(sizeof(*ctx));
+    if (ctx != NULL) {
+        ctx->devId = INVALID_DEVID;
+    }
     if ((ctx != NULL) && (wc_InitRng(&ctx->rng) != 0)) {
         OPENSSL_free(ctx);
         ctx = NULL;
@@ -372,6 +376,49 @@
     return ok;
 }
 
+/*
+ * Get the table of parameters that can be set on wolfProv.
+ *
+ * @param [in] provCtx  Unused.
+ * @return  Table of settable parameters.
+ */
+static const OSSL_PARAM* wolfprov_settable_params(void* provCtx)
+{
+    static const OSSL_PARAM settable[] = {
+        OSSL_PARAM_int("wolfprovider_devid", NULL),
+        OSSL_PARAM_END
+    };
+    (void)provCtx;
+    return settable;
+}
+
+/*
+ * Set parameters on the provider context.
+ *
+ * @param [in] provCtx  Provider context.
+ * @param [in] params   Parameters to set.
+ * @return  1 on success.
+ * @return  0 on failure.
+ */
+static int wolfprov_set_params(void* provCtx, const OSSL_PARAM params[])
+{
+    int ok = 1;
+    const OSSL_PARAM* p;
+    WOLFPROV_CTX* ctx = (WOLFPROV_CTX*)provCtx;
+
+    WOLFPROV_ENTER(WP_LOG_COMP_PROVIDER, "wolfprov_set_params");
+
+    p = OSSL_PARAM_locate_const(params, "wolfprovider_devid");
+    if (p != NULL) {
+        if (!OSSL_PARAM_get_int(p, &ctx->devId)) {
+            ok = 0;
+        }
+    }
+
+    WOLFPROV_LEAVE(WP_LOG_COMP_PROVIDER, __FILE__ ":" WOLFPROV_STRINGIZE(__LINE__), ok);
+    return ok;
+}
+
 #ifdef HAVE_FIPS
 /* Properties of wolfSSL provider: name and FIPS wolfSSL. */
 #define WOLFPROV_PROPERTIES     "provider=wolfprov,fips=yes"
